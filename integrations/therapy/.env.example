# Therapy — Environment Configuration
# Copy this file to .env and fill in the values.
# This is the ONLY difference between environments.

# ============================================
# Database (Supabase PostgreSQL — direct connection)
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.tpppqevmgwozyimdnxok.supabase.co:5432/postgres

# ============================================
# Auth
# ============================================
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# App
# ============================================
DEBUG=false
APP_ENV=production
APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ============================================
# Ports (for docker-compose)
# ============================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================================
# Frontend
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
